        RSEG CODE:CODE:NOROOT(1)
//  636 void CPlatform::BuzzerTimerFrequencySet(uint16_t uiFrequency)
??BuzzerTimerFrequencySet:
//  637 {
        CALL    ?PROLOGUE4_L09
        MOVW    R25:R24, R17:R16
//  638     unsigned short usCompareMatch;
//  639 
//  640     // half-period time.
//  641     usCompareMatch = ((F_CPU / (2UL * uiFrequency)) - 1UL);
        MOVW    R21:R20, R25:R24
        LDI     R22, 0
        LDI     R23, 0
        LSL     R20
        ROL     R21
        ROL     R22
        ROL     R23
        LDI     R16, 0
        LDI     R17, 128
        LDI     R18, 112
        LDI     R19, 0
        CALL    ?UL_DIVMOD_L03
        SUBI    R16, 1
        SBCI    R17, 0
        MOVW    R27:R26, R17:R16
//  642     // Срабатывает по Top совпадению значения в ICR3.
//  643     // Если Top по совпадению значения в OCR3A, то нельзя использовать COM3A вывод.
//  644     ICR3 = usCompareMatch * 2;
        MOVW    R17:R16, R27:R26
        LSL     R16
        ROL     R17
        STS     (_A_ICR3 + 1), R17
        STS     _A_ICR3, R16
//  645     OCR3A = usCompareMatch;
        STS     (_A_OCR3A + 1), R27
        STS     _A_OCR3A, R26
//  646     OCR3B = usCompareMatch;
        STS     (_A_OCR3B + 1), R27
        STS     _A_OCR3B, R26
//  647 
//  648     // Fast PWM Mode Top OCRn, prescaller - 1,
//  649     // Clear OC3B on compare match (set output to low level).
//  650     // Set OC3A on compare match (set output to high level).
//  651     TCCR3A = (1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31);
        LDI     R16, 226
        STS     _A_TCCR3A, R16
//  652     TCCR3B = (1 << WGM33) | (1 << WGM32) | (1 << CS30);
        LDI     R16, 25
        STS     _A_TCCR3B, R16
//  653 };
        LDI     R30, 4
        JMP     ?EPILOGUE_B4_L09
        REQUIRE _A_ICR3
        REQUIRE _A_OCR3A
        REQUIRE _A_OCR3B
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  654 
//  655 //-----------------------------------------------------------------------------------------------------

        RSEG CODE:CODE:NOROOT(1)
//  656 void CPlatform::BuzzerTimerStop(void)
??BuzzerTimerStop:
//  657 {
//  658     // timer off.
//  659     TCCR3A &= ~((1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31));
        LDS     R16, _A_TCCR3A
        ANDI    R16, 0x1D
        STS     _A_TCCR3A, R16
//  660     TCCR3B &= ~((1 << WGM33) | (1 << WGM32) | (1 << CS30));
        LDS     R16, _A_TCCR3B
        ANDI    R16, 0xE6
        STS     _A_TCCR3B, R16
//  661 };
        RET
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  662 
//  663 //-----------------------------------------------------------------------------------------------------
//  664 void CPlatform::SystemTickInit(void)
//  665 {
//  666 #define MAIN_TIMER_TICK_RATE_HZ 1000
//  667 
//  668 //#define TIMER1_INTERRUPT
//  669 #define TIMER2_INTERRUPT
//  670 
//  671 
//  672 #ifdef TIMER2_INTERRUPT
//  673     /* Hardware constants for timer 2. */
//  674 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM21) )
//  675 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS21) | _BV(CS20)) )
//  676 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  677 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE2) )
//  678 #endif //TIMER2_INTERRUPT
//  679 
//  680 #ifdef TIMER1_INTERRUPT
//  681     /* Hardware constants for timer 1. */
//  682 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM12) )
//  683 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS11) | _BV(CS10)) )
//  684 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  685 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE1A) )
//  686 #endif //TIMER1_INTERRUPT
//  687 
//  688 #ifdef TIMER2_INTERRUPT
//  689 
//  690     /*
//  691      * Setup timer 2 compare match A to generate a tick interrupt.
//  692      */
//  693 //  TMR2 mega128a
//  694     unsigned long ulCompareMatch;
//  695     unsigned char ucLowByte;
//  696 
//  697     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  698     selected for the configCPU_CLOCK_HZ clock. */
//  699 
//  700 //ulCompareMatch  = (configCPU_CLOCK_HZ / prescaller) / period
//  701 
//  702     ulCompareMatch = F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  703 
//  704     /* We only have 16 bits so have to scale to get our required tick rate. */
//  705     ulCompareMatch /= portCLOCK_PRESCALER;
//  706 
//  707     /* Adjust for correct value. */
//  708     ulCompareMatch -= ( unsigned long ) 1;
//  709 
//  710     /* Setup compare match value for compare match A.  Interrupts are disabled
//  711     before this is called so we need not worry here. */
//  712     OCR2 = ulCompareMatch;
//  713 
//  714     /* Setup clock Sourse and compare match behaviour. */
//  715     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  716     TCCR2 = ucLowByte;
//  717 
//  718     /* Enable the interrupt - this is okay as interrupt are currently globally
//  719     disabled. */
//  720     ucLowByte = TIMSK;
//  721     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  722     TIMSK = ucLowByte;
//  723 
//  724 #endif //TIMER2_INTERRUPT
//  725 
//  726 #ifdef TIMER1_INTERRUPT
//  727 
//  728 // mega128a
//  729     unsigned long ulCompareMatch;
//  730     unsigned char ucLowByte;
//  731 
//  732     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  733     selected for the configCPU_CLOCK_HZ clock. */
//  734 
//  735     ulCompareMatch = CPlatform::F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  736 
//  737     /* We only have 16 bits so have to scale to get our required tick rate. */
//  738     ulCompareMatch /= portCLOCK_PRESCALER;
//  739 
//  740     /* Adjust for correct value. */
//  741     ulCompareMatch -= ( unsigned long ) 1;
//  742 
//  743     /* Setup compare match value for compare match A.  Interrupts are disabled
//  744     before this is called so we need not worry here. */
//  745     OCR1A = ulCompareMatch;
//  746 
//  747     /* Setup clock Sourse and compare match behaviour. */
//  748     TCCR1A &= ~(_BV(WGM11) | _BV(WGM10));
//  749     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  750     TCCR1B = ucLowByte;
//  751 
//  752     /* Enable the interrupt - this is okay as interrupt are currently globally
//  753     disabled. */
//  754     ucLowByte = TIMSK;
//  755     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  756     TIMSK = ucLowByte;
//  757 
//  758 #endif //TIMER1_INTERRUPT
//  759 
//  760 }
