        RSEG CODE:CODE:NOROOT(1)
//  591 void CPlatform::BuzzerTimerFrequencySet(uint16_t uiFrequency)
??BuzzerTimerFrequencySet:
//  592 {
//  593     unsigned short usCompareMatch;
//  594 
//  595     // half-period time.
//  596     usCompareMatch = ((F_CPU / (2UL * uiFrequency)) - 1UL);
        MOVW    R21:R20, R17:R16
        LDI     R22, 0
        LDI     R23, 0
        LSL     R20
        ROL     R21
        ROL     R22
        RCALL   ?Subroutine3
//  597     // Ńđŕáŕňűâŕĺň ďî Top ńîâďŕäĺíčţ çíŕ÷ĺíč˙ â ICR3.
//  598     // Ĺńëč Top ďî ńîâďŕäĺíčţ çíŕ÷ĺíč˙ â OCR3A, ňî íĺëüç˙ čńďîëüçîâŕňü COM3A âűâîä.
//  599     ICR3 = usCompareMatch * 2;
??CrossCallReturnLabel_3:
        MOVW    R19:R18, R17:R16
        LSL     R18
        ROL     R19
        STS     (_A_ICR3 + 1), R19
        STS     _A_ICR3, R18
//  600     OCR3A = usCompareMatch;
        STS     (_A_OCR3A + 1), R17
        STS     _A_OCR3A, R16
//  601     OCR3B = usCompareMatch;
        STS     (_A_OCR3B + 1), R17
        STS     _A_OCR3B, R16
//  602 
//  603     // Fast PWM Mode Top OCRn, prescaller - 1,
//  604     // Clear OC3B on compare match (set output to low level).
//  605     // Set OC3A on compare match (set output to high level).
//  606     TCCR3A = (1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31);
        LDI     R16, 226
        STS     _A_TCCR3A, R16
//  607     TCCR3B = (1 << WGM33) | (1 << WGM32) | (1 << CS30);
        LDI     R16, 25
        REQUIRE ?Subroutine27
        REQUIRE _A_ICR3
        REQUIRE _A_OCR3A
        REQUIRE _A_OCR3B
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
        ;               // Fall through to label ?Subroutine27
//  608 };

