//  907 // ╤шЁхэр
//  908 //-----------------------------------------------------------------------------------------------------

        RSEG CODE:CODE:NOROOT(1)
//  909 void CPlatform::BuzzerTimerFrequencySet(uint16_t uiFrequency)
??BuzzerTimerFrequencySet:
//  910 {
        CALL    ?PROLOGUE4_L09
        MOVW    R25:R24, R17:R16
//  911     unsigned short usCompareMatch;
//  912 
//  913     // half-period time.
//  914     usCompareMatch = ((F_CPU / (2UL * uiFrequency)) - 1UL);
        MOVW    R21:R20, R25:R24
        LDI     R22, 0
        LDI     R23, 0
        LSL     R20
        ROL     R21
        ROL     R22
        ROL     R23
        LDI     R16, 0
        LDI     R17, 128
        LDI     R18, 112
        LDI     R19, 0
        CALL    ?UL_DIVMOD_L03
        SUBI    R16, 1
        SBCI    R17, 0
        MOVW    R27:R26, R17:R16
//  915     // ╤ЁрсрҐ√трхҐ яю Top ёютярфхэш■ чэріхэш  т ICR3.
//  916     // ┼ёыш Top яю ёютярфхэш■ чэріхэш  т OCR3A, Ґю эхы№ч  шёяюы№чютрҐ№ COM3A т√тюф.
//  917     ICR3 = usCompareMatch * 2;
        MOVW    R17:R16, R27:R26
        LSL     R16
        ROL     R17
        STS     (_A_ICR3 + 1), R17
        STS     _A_ICR3, R16
//  918     OCR3A = usCompareMatch;
        STS     (_A_OCR3A + 1), R27
        STS     _A_OCR3A, R26
//  919     OCR3B = usCompareMatch;
        STS     (_A_OCR3B + 1), R27
        STS     _A_OCR3B, R26
//  920 
//  921     // Fast PWM Mode Top OCRn, prescaller - 1,
//  922     // Clear OC3B on compare match (set output to low level).
//  923     // Set OC3A on compare match (set output to high level).
//  924     TCCR3A = (1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31);
        LDI     R16, 226
        STS     _A_TCCR3A, R16
//  925     TCCR3B = (1 << WGM33) | (1 << WGM32) | (1 << CS30);
        LDI     R16, 25
        STS     _A_TCCR3B, R16
//  926 };
        LDI     R30, 4
        JMP     ?EPILOGUE_B4_L09
        REQUIRE _A_ICR3
        REQUIRE _A_OCR3A
        REQUIRE _A_OCR3B
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  927 
//  928 //-----------------------------------------------------------------------------------------------------

        RSEG CODE:CODE:NOROOT(1)
//  929 void CPlatform::BuzzerTimerStop(void)
??BuzzerTimerStop:
//  930 {
//  931     // timer off.
//  932     TCCR3A &= ~((1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31));
        LDS     R16, _A_TCCR3A
        ANDI    R16, 0x1D
        STS     _A_TCCR3A, R16
//  933     TCCR3B &= ~((1 << WGM33) | (1 << WGM32) | (1 << CS30));
        LDS     R16, _A_TCCR3B
        ANDI    R16, 0xE6
        STS     _A_TCCR3B, R16
//  934 };
        RET
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  935 
//  936 //-----------------------------------------------------------------------------------------------------
//  937 void CPlatform::SystemTickInit(void)
//  938 {
//  939 #define MAIN_TIMER_TICK_RATE_HZ 1000
//  940 
//  941 //#define TIMER1_INTERRUPT
//  942 #define TIMER2_INTERRUPT
//  943 
//  944 
//  945 #ifdef TIMER2_INTERRUPT
//  946     /* Hardware constants for timer 2. */
//  947 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM21) )
//  948 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS21) | _BV(CS20)) )
//  949 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  950 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE2) )
//  951 #endif //TIMER2_INTERRUPT
//  952 
//  953 #ifdef TIMER1_INTERRUPT
//  954     /* Hardware constants for timer 1. */
//  955 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM12) )
//  956 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS11) | _BV(CS10)) )
//  957 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  958 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE1A) )
//  959 #endif //TIMER1_INTERRUPT
//  960 
//  961 #ifdef TIMER2_INTERRUPT
//  962 
//  963     /*
//  964      * Setup timer 2 compare match A to generate a tick interrupt.
//  965      */
//  966 //  TMR2 mega128a
//  967     unsigned long ulCompareMatch;
//  968     unsigned char ucLowByte;
//  969 
//  970     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  971     selected for the configCPU_CLOCK_HZ clock. */
//  972 
//  973 //ulCompareMatch  = (configCPU_CLOCK_HZ / prescaller) / period
//  974 
//  975     ulCompareMatch = F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  976 
//  977     /* We only have 16 bits so have to scale to get our required tick rate. */
//  978     ulCompareMatch /= portCLOCK_PRESCALER;
//  979 
//  980     /* Adjust for correct value. */
//  981     ulCompareMatch -= ( unsigned long ) 1;
//  982 
//  983     /* Setup compare match value for compare match A.  Interrupts are disabled
//  984     before this is called so we need not worry here. */
//  985     OCR2 = ulCompareMatch;
//  986 
//  987     /* Setup clock Sourse and compare match behaviour. */
//  988     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  989     TCCR2 = ucLowByte;
//  990 
//  991     /* Enable the interrupt - this is okay as interrupt are currently globally
//  992     disabled. */
//  993     ucLowByte = TIMSK;
//  994     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  995     TIMSK = ucLowByte;
//  996 
//  997 #endif //TIMER2_INTERRUPT
//  998 
//  999 #ifdef TIMER1_INTERRUPT
// 1000 
// 1001 // mega128a
// 1002     unsigned long ulCompareMatch;
// 1003     unsigned char ucLowByte;
// 1004 
// 1005     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
