        RSEG CODE:CODE:NOROOT(1)
//  897 void CPlatform::BuzzerTimerFrequencySet(uint16_t uiFrequency)
??BuzzerTimerFrequencySet:
//  898 {
        CALL    ?PROLOGUE4_L09
        MOVW    R25:R24, R17:R16
//  899     unsigned short usCompareMatch;
//  900 
//  901     // half-period time.
//  902     usCompareMatch = ((F_CPU / (2UL * uiFrequency)) - 1UL);
        MOVW    R21:R20, R25:R24
        LDI     R22, 0
        LDI     R23, 0
        LSL     R20
        ROL     R21
        ROL     R22
        ROL     R23
        LDI     R16, 0
        LDI     R17, 128
        LDI     R18, 112
        LDI     R19, 0
        CALL    ?UL_DIVMOD_L03
        SUBI    R16, 1
        SBCI    R17, 0
        MOVW    R27:R26, R17:R16
//  903     // Срабатывает по Top совпадению значения в ICR3.
//  904     // Если Top по совпадению значения в OCR3A, то нельзя использовать COM3A вывод.
//  905     ICR3 = usCompareMatch * 2;
        MOVW    R17:R16, R27:R26
        LSL     R16
        ROL     R17
        STS     (_A_ICR3 + 1), R17
        STS     _A_ICR3, R16
//  906     OCR3A = usCompareMatch;
        STS     (_A_OCR3A + 1), R27
        STS     _A_OCR3A, R26
//  907     OCR3B = usCompareMatch;
        STS     (_A_OCR3B + 1), R27
        STS     _A_OCR3B, R26
//  908 
//  909     // Fast PWM Mode Top OCRn, prescaller - 1,
//  910     // Clear OC3B on compare match (set output to low level).
//  911     // Set OC3A on compare match (set output to high level).
//  912     TCCR3A = (1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31);
        LDI     R16, 226
        STS     _A_TCCR3A, R16
//  913     TCCR3B = (1 << WGM33) | (1 << WGM32) | (1 << CS30);
        LDI     R16, 25
        STS     _A_TCCR3B, R16
//  914 };
        LDI     R30, 4
        JMP     ?EPILOGUE_B4_L09
        REQUIRE _A_ICR3
        REQUIRE _A_OCR3A
        REQUIRE _A_OCR3B
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  915 
//  916 //-----------------------------------------------------------------------------------------------------

        RSEG CODE:CODE:NOROOT(1)
//  917 void CPlatform::BuzzerTimerStop(void)
??BuzzerTimerStop:
//  918 {
//  919     // timer off.
//  920     TCCR3A &= ~((1 << COM3B1) | (1 << COM3A1) | (1 << COM3A0) | (1 << WGM31));
        LDS     R16, _A_TCCR3A
        ANDI    R16, 0x1D
        STS     _A_TCCR3A, R16
//  921     TCCR3B &= ~((1 << WGM33) | (1 << WGM32) | (1 << CS30));
        LDS     R16, _A_TCCR3B
        ANDI    R16, 0xE6
        STS     _A_TCCR3B, R16
//  922 };
        RET
        REQUIRE _A_TCCR3A
        REQUIRE _A_TCCR3B
//  923 
//  924 //-----------------------------------------------------------------------------------------------------
//  925 void CPlatform::SystemTickInit(void)
//  926 {
//  927 #define MAIN_TIMER_TICK_RATE_HZ 1000
//  928 
//  929 //#define TIMER1_INTERRUPT
//  930 #define TIMER2_INTERRUPT
//  931 
//  932 
//  933 #ifdef TIMER2_INTERRUPT
//  934     /* Hardware constants for timer 2. */
//  935 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM21) )
//  936 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS21) | _BV(CS20)) )
//  937 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  938 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE2) )
//  939 #endif //TIMER2_INTERRUPT
//  940 
//  941 #ifdef TIMER1_INTERRUPT
//  942     /* Hardware constants for timer 1. */
//  943 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM12) )
//  944 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS11) | _BV(CS10)) )
//  945 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  946 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE1A) )
//  947 #endif //TIMER1_INTERRUPT
//  948 
//  949 #ifdef TIMER2_INTERRUPT
//  950 
//  951     /*
//  952      * Setup timer 2 compare match A to generate a tick interrupt.
//  953      */
//  954 //  TMR2 mega128a
//  955     unsigned long ulCompareMatch;
//  956     unsigned char ucLowByte;
//  957 
//  958     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  959     selected for the configCPU_CLOCK_HZ clock. */
//  960 
//  961 //ulCompareMatch  = (configCPU_CLOCK_HZ / prescaller) / period
//  962 
//  963     ulCompareMatch = F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  964 
//  965     /* We only have 16 bits so have to scale to get our required tick rate. */
//  966     ulCompareMatch /= portCLOCK_PRESCALER;
//  967 
//  968     /* Adjust for correct value. */
//  969     ulCompareMatch -= ( unsigned long ) 1;
//  970 
//  971     /* Setup compare match value for compare match A.  Interrupts are disabled
//  972     before this is called so we need not worry here. */
//  973     OCR2 = ulCompareMatch;
//  974 
//  975     /* Setup clock Sourse and compare match behaviour. */
//  976     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  977     TCCR2 = ucLowByte;
//  978 
//  979     /* Enable the interrupt - this is okay as interrupt are currently globally
//  980     disabled. */
//  981     ucLowByte = TIMSK;
//  982     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  983     TIMSK = ucLowByte;
//  984 
//  985 #endif //TIMER2_INTERRUPT
//  986 
//  987 #ifdef TIMER1_INTERRUPT
//  988 
//  989 // mega128a
//  990     unsigned long ulCompareMatch;
//  991     unsigned char ucLowByte;
//  992 
//  993     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  994     selected for the configCPU_CLOCK_HZ clock. */
//  995 
//  996     ulCompareMatch = CPlatform::F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  997 
//  998     /* We only have 16 bits so have to scale to get our required tick rate. */
//  999     ulCompareMatch /= portCLOCK_PRESCALER;
// 1000 
// 1001     /* Adjust for correct value. */
// 1002     ulCompareMatch -= ( unsigned long ) 1;
// 1003 
// 1004     /* Setup compare match value for compare match A.  Interrupts are disabled
// 1005     before this is called so we need not worry here. */
// 1006     OCR1A = ulCompareMatch;
// 1007 
// 1008     /* Setup clock Sourse and compare match behaviour. */
// 1009     TCCR1A &= ~(_BV(WGM11) | _BV(WGM10));
// 1010     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
// 1011     TCCR1B = ucLowByte;
// 1012 
// 1013     /* Enable the interrupt - this is okay as interrupt are currently globally
// 1014     disabled. */
// 1015     ucLowByte = TIMSK;
// 1016     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
// 1017     TIMSK = ucLowByte;
// 1018 
// 1019 #endif //TIMER1_INTERRUPT
// 1020 
// 1021 }
// 1022 
// 1023 //-----------------------------------------------------------------------------------------------------
// 1024 #ifdef TIMER1_INTERRUPT
// 1025 // Прерывание TIMER1_COMPA_vect
// 1026 __interrupt void SystemTickInterrupt(void)
// 1027 {
// 1028     CPlatform::IncrementSystemTick();
// 1029 }
// 1030 #endif //TIMER1_INTERRUPT
// 1031 //-----------------------------------------------------------------------------------------------------
// 1032 #ifdef TIMER2_INTERRUPT
// 1033 // Прерывание TIMER2_COMP_vect
// 1034 #pragma vector = TIMER2_COMP_vect	// Прерывание по совпадению TMR2 с OCR2

        RSEG CODE:CODE:NOROOT(1)
        CALL_GRAPH_ROOT ??SystemTickInterrupt, "interrupt"
// 1035 __interrupt void SystemTickInterrupt(void)
??SystemTickInterrupt:
// 1036 {
        ST      -Y, R25
        ST      -Y, R24
        ST      -Y, R31
        ST      -Y, R30
        ST      -Y, R3
        ST      -Y, R2
        ST      -Y, R1
        ST      -Y, R0
        ST      -Y, R23
        ST      -Y, R22
        ST      -Y, R21
        ST      -Y, R20
        ST      -Y, R19
        ST      -Y, R18
        ST      -Y, R17
        ST      -Y, R16
        IN      R24, 0x3F
        IN      R25, 0x3B
// 1037     CPlatform::IncrementSystemTick();
        CALL    ??IncrementSystemTick
// 1038 }
        OUT     0x3B, R25
        OUT     0x3F, R24
        LD      R16, Y+
        LD      R17, Y+
        LD      R18, Y+
        LD      R19, Y+
        LD      R20, Y+
        LD      R21, Y+
        LD      R22, Y+
        LD      R23, Y+
        LD      R0, Y+
        LD      R1, Y+
