//  618 //-----------------------------------------------------------------------------------------------------
//  619 void CPlatform::SystemTickInit(void)
//  620 {
//  621 #define MAIN_TIMER_TICK_RATE_HZ 1000
//  622 
//  623 //#define TIMER1_INTERRUPT
//  624 #define TIMER2_INTERRUPT
//  625 
//  626 
//  627 #ifdef TIMER2_INTERRUPT
//  628     /* Hardware constants for timer 2. */
//  629 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM21) )
//  630 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS21) | _BV(CS20)) )
//  631 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  632 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE2) )
//  633 #endif //TIMER2_INTERRUPT
//  634 
//  635 #ifdef TIMER1_INTERRUPT
//  636     /* Hardware constants for timer 1. */
//  637 #define portCLEAR_COUNTER_ON_MATCH              ( ( unsigned char ) _BV(WGM12) )
//  638 #define portPRESCALE_64                         ( ( unsigned char ) (_BV(CS11) | _BV(CS10)) )
//  639 #define portCLOCK_PRESCALER                     ( ( unsigned long ) 64 )
//  640 #define portCOMPARE_MATCH_A_INTERRUPT_ENABLE    ( ( unsigned char ) _BV(OCIE1A) )
//  641 #endif //TIMER1_INTERRUPT
//  642 
//  643 #ifdef TIMER2_INTERRUPT
//  644 
//  645     /*
//  646      * Setup timer 2 compare match A to generate a tick interrupt.
//  647      */
//  648 //  TMR2 mega128a
//  649     unsigned long ulCompareMatch;
//  650     unsigned char ucLowByte;
//  651 
//  652     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  653     selected for the configCPU_CLOCK_HZ clock. */
//  654 
//  655 //ulCompareMatch  = (configCPU_CLOCK_HZ / prescaller) / period
//  656 
//  657     ulCompareMatch = F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  658 
//  659     /* We only have 16 bits so have to scale to get our required tick rate. */
//  660     ulCompareMatch /= portCLOCK_PRESCALER;
//  661 
//  662     /* Adjust for correct value. */
//  663     ulCompareMatch -= ( unsigned long ) 1;
//  664 
//  665     /* Setup compare match value for compare match A.  Interrupts are disabled
//  666     before this is called so we need not worry here. */
//  667     OCR2 = ulCompareMatch;
//  668 
//  669     /* Setup clock Sourse and compare match behaviour. */
//  670     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  671     TCCR2 = ucLowByte;
//  672 
//  673     /* Enable the interrupt - this is okay as interrupt are currently globally
//  674     disabled. */
//  675     ucLowByte = TIMSK;
//  676     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  677     TIMSK = ucLowByte;
//  678 
//  679 #endif //TIMER2_INTERRUPT
//  680 
//  681 #ifdef TIMER1_INTERRUPT
//  682 
//  683 // mega128a
//  684     unsigned long ulCompareMatch;
//  685     unsigned char ucLowByte;
//  686 
//  687     /* Using 16bit timer 1 to generate the tick.  Correct fuses must be
//  688     selected for the configCPU_CLOCK_HZ clock. */
//  689 
//  690     ulCompareMatch = CPlatform::F_CPU / MAIN_TIMER_TICK_RATE_HZ;
//  691 
//  692     /* We only have 16 bits so have to scale to get our required tick rate. */
//  693     ulCompareMatch /= portCLOCK_PRESCALER;
//  694 
//  695     /* Adjust for correct value. */
//  696     ulCompareMatch -= ( unsigned long ) 1;
//  697 
//  698     /* Setup compare match value for compare match A.  Interrupts are disabled
//  699     before this is called so we need not worry here. */
//  700     OCR1A = ulCompareMatch;
//  701 
//  702     /* Setup clock Sourse and compare match behaviour. */
//  703     TCCR1A &= ~(_BV(WGM11) | _BV(WGM10));
//  704     ucLowByte = portCLEAR_COUNTER_ON_MATCH | portPRESCALE_64;
//  705     TCCR1B = ucLowByte;
//  706 
//  707     /* Enable the interrupt - this is okay as interrupt are currently globally
//  708     disabled. */
//  709     ucLowByte = TIMSK;
//  710     ucLowByte |= portCOMPARE_MATCH_A_INTERRUPT_ENABLE;
//  711     TIMSK = ucLowByte;
//  712 
//  713 #endif //TIMER1_INTERRUPT
//  714 
//  715 }
