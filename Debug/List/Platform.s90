        CALL    ??IncrementSystemTick
//  777 }
        OUT     0x3B, R25
        OUT     0x3F, R24
        LD      R16, Y+
        LD      R17, Y+
        LD      R18, Y+
        LD      R19, Y+
        LD      R20, Y+
        LD      R21, Y+
