//  693         uiLength = ResponseException(uiSlave,
//  694                                      uiFunctionCode,
//  695                                      MODBUS_EXCEPTION_SLAVE_OR_SERVER_BUSY,
//  696                                      puiResponse);
        MOVW    R23:R22, R5:R4
        LDI     R20, 6
        MOV     R19, R10
        MOV     R18, R11
        MOVW    R17:R16, R27:R26
        RCALL   ??ResponseException
        MOVW    R25:R24, R17:R16
        RJMP    ??PollProgramming_2
//  697     }
//  698     else
//  699     {
//  700         uiLength = ResponseException(uiSlave,
//  701                                      uiFunctionCode,
//  702                                      MODBUS_EXCEPTION_ILLEGAL_FUNCTION,
