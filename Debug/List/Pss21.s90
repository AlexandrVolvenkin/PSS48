//  125                          DISCRETE_DATA_ARRAY_LENGTH,
//  126                          HOLDING_REGISTERS_ARRAY_LENGTH,
//  127                          INPUT_REGISTERS_ARRAY_LENGTH);
        LDI     R16, 8
        LDI     R17, 0
