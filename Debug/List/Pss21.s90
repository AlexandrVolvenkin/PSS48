//  118                          CPss21::m_auiReceiveMessageBuff,
//  119                          CPss21::m_auiReceiveMessageBuff,//CPss21::m_auiTransmitMessageBuff,
//  120                          CPss21::m_aucRtuDiscreteDataArray,//CPss21::m_aucRtuCoilsArray,
