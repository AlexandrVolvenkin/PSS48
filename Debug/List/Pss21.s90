        LDI     R17, (??m_auiReceiveMessageBuff) >> 8
        ST      -Y, R17
        ST      -Y, R16
        LDI     R16, LOW(??m_auiReceiveMessageBuff)
        LDI     R17, (??m_auiReceiveMessageBuff) >> 8
