//  132     m_xModbusRtuOne.SlaveSet(CPss21::m_xModbusSettings.NetAddress);
        LDS     R18, ??m_xModbusSettings
        LDI     R30, LOW(??m_xModbusRtuOne)
        LDI     R31, (??m_xModbusRtuOne) >> 8
