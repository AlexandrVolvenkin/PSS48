//  129                          DISCRETE_DATA_ARRAY_LENGTH,
//  130                          HOLDING_REGISTERS_ARRAY_LENGTH,
//  131                          INPUT_REGISTERS_ARRAY_LENGTH);
        LDI     R16, 8
        LDI     R17, 0
